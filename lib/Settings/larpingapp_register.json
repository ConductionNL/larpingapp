{
  "openapi": "3.0.0",
  "info": {
    "title": "LarpingApp Register",
    "description": "Live Action Role Playing character management register for the LarpingApp Nextcloud app. Manages characters, players, abilities, skills, items, conditions, effects, events, and settings.",
    "version": "1.0.0"
  },
  "x-openregister": {
    "type": "application",
    "app": "larpingapp",
    "openregister": "^v0.2.10",
    "description": "LARP character management data model — thin client on OpenRegister, no own database tables"
  },
  "components": {
    "registers": {
      "larpingapp": {
        "slug": "larpingapp",
        "title": "LarpingApp",
        "version": "1.0.0",
        "description": "Live Action Role Playing character management register — manages characters, players, abilities, skills, items, conditions, effects, events, and game settings.",
        "published": "2026-03-01T00:00:00+00:00",
        "schemas": [
          "character",
          "player",
          "ability",
          "skill",
          "item",
          "condition",
          "effect",
          "event",
          "setting"
        ],
        "tablePrefix": "",
        "folder": "Open Registers/LarpingApp"
      }
    },
    "schemas": {
      "character": {
        "slug": "character",
        "title": "Character",
        "icon": "BriefcaseAccountOutline",
        "version": "1.0.0",
        "summary": "A playable or non-playable character in the LARP game",
        "description": "Represents a character entity with stats, skills, items, conditions, and event participation. Characters can be player characters, NPCs, or other types. Game masters approve characters before play.",
        "required": [
          "name",
          "ocName"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "The chosen in-game name for this character",
            "maxLength": 255,
            "minLength": 1
          },
          "ocName": {
            "type": "string",
            "description": "The name of the player playing this character",
            "maxLength": 255
          },
          "description": {
            "type": "string",
            "description": "Public description visible to all players",
            "maxLength": 2555
          },
          "background": {
            "type": "string",
            "description": "Character background story (visible to GMs only)",
            "maxLength": 2555,
            "visible": false
          },
          "type": {
            "type": "string",
            "description": "Character type classification",
            "enum": [
              "player",
              "npc",
              "other"
            ],
            "default": "player",
            "title": "Type",
            "facetable": true
          },
          "approved": {
            "type": "string",
            "description": "Approval status by game master",
            "enum": [
              "no",
              "approved"
            ],
            "default": "no",
            "title": "Approved",
            "facetable": true
          },
          "gold": {
            "type": "integer",
            "description": "Amount of gold pieces",
            "default": 0,
            "visible": false
          },
          "silver": {
            "type": "integer",
            "description": "Amount of silver pieces",
            "default": 0,
            "visible": false
          },
          "copper": {
            "type": "integer",
            "description": "Amount of copper pieces",
            "default": 0,
            "visible": false
          },
          "faith": {
            "type": "string",
            "description": "The faith or religion of the character",
            "maxLength": 2555,
            "visible": false
          },
          "slNotesPublic": {
            "type": "string",
            "description": "Game master notes visible to players",
            "maxLength": 2555,
            "visible": false
          },
          "slNotesPrivate": {
            "type": "string",
            "description": "Game master notes NOT visible to players",
            "maxLength": 2555,
            "visible": false
          },
          "card": {
            "type": "string",
            "description": "Character card as markdown table",
            "maxLength": 5000,
            "visible": false
          },
          "itemsAndMoney": {
            "type": "string",
            "description": "Notes about items and money",
            "maxLength": 2555,
            "visible": false
          },
          "notice": {
            "type": "string",
            "description": "Automatic system notices",
            "maxLength": 2555,
            "visible": false
          },
          "skills": {
            "type": "array",
            "description": "Skills this character possesses",
            "items": {
              "type": "string",
              "format": "uuid"
            },
            "visible": false
          },
          "items": {
            "type": "array",
            "description": "Items this character owns",
            "items": {
              "type": "string",
              "format": "uuid"
            },
            "visible": false
          },
          "conditions": {
            "type": "array",
            "description": "Conditions currently affecting this character",
            "items": {
              "type": "string",
              "format": "uuid"
            },
            "visible": false
          },
          "events": {
            "type": "array",
            "description": "Events this character is subscribed to",
            "items": {
              "type": "string",
              "format": "uuid"
            },
            "visible": false
          }
        }
      },
      "player": {
        "slug": "player",
        "title": "Player",
        "icon": "AccountGroupOutline",
        "version": "1.0.0",
        "summary": "A real-world player participating in the LARP",
        "description": "Represents a player who controls one or more characters. Tracks player identity and contact information.",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Full name of the player",
            "maxLength": 255,
            "minLength": 1
          },
          "description": {
            "type": "string",
            "description": "Notes about the player",
            "maxLength": 2555
          }
        }
      },
      "ability": {
        "slug": "ability",
        "title": "Ability",
        "icon": "ShieldSwordOutline",
        "version": "1.0.0",
        "summary": "A numeric stat tracked on characters (e.g., XP, Mana, Health)",
        "description": "Represents a numeric ability or stat that characters track. Effects modify abilities by adding or subtracting from the base value. Used for experience points, mana, health, armor, and other quantifiable attributes.",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Unique name of the ability (e.g., Experience Points, Mana)",
            "maxLength": 255,
            "minLength": 1
          },
          "description": {
            "type": "string",
            "description": "What this ability represents within the game setting",
            "maxLength": 2555
          },
          "base": {
            "type": "integer",
            "description": "Starting value for all characters",
            "default": 0
          }
        }
      },
      "skill": {
        "slug": "skill",
        "title": "Skill",
        "icon": "SwordCross",
        "version": "1.0.0",
        "summary": "A learnable ability that characters can acquire",
        "description": "Represents a skill that characters can learn, usually purchased with experience points. Skills provide effects and may have prerequisites (other skills, stats, conditions, or effects).",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the skill (e.g., Healing LvL 1)",
            "maxLength": 255,
            "minLength": 1
          },
          "description": {
            "type": "string",
            "description": "In-game flavor description of the skill",
            "maxLength": 2555
          },
          "effect": {
            "type": "string",
            "description": "Technical description of what the skill does mechanically",
            "maxLength": 2555,
            "visible": false
          },
          "effects": {
            "type": "array",
            "description": "Effects applied when this skill is taken",
            "items": {
              "type": "string",
              "format": "uuid"
            },
            "visible": false
          },
          "requiredSkills": {
            "type": "array",
            "description": "Prerequisite skills needed before learning this skill",
            "items": {
              "type": "string",
              "format": "uuid"
            },
            "visible": false
          },
          "requiredStats": {
            "type": "array",
            "description": "Required ability scores",
            "items": {
              "type": "string",
              "format": "uuid"
            },
            "visible": false
          },
          "requiredConditions": {
            "type": "array",
            "description": "Required conditions",
            "items": {
              "type": "string",
              "format": "uuid"
            },
            "visible": false
          },
          "requiredEffects": {
            "type": "array",
            "description": "Required effects",
            "items": {
              "type": "string",
              "format": "uuid"
            },
            "visible": false
          },
          "requiredScore": {
            "type": "integer",
            "description": "Minimum ability score needed when requirements are abilities",
            "visible": false
          }
        }
      },
      "item": {
        "slug": "item",
        "title": "Item",
        "icon": "Sword",
        "version": "1.0.0",
        "summary": "A magical or special item that characters can own",
        "description": "Represents a special or magical item in the game. Items provide effects to their holder. Items can be unique artifacts (only one instance exists) or regular items.",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Item name (e.g., Hand of Vecna)",
            "maxLength": 255,
            "minLength": 1
          },
          "description": {
            "type": "string",
            "description": "Player-visible description with story pointers",
            "maxLength": 2555
          },
          "effect": {
            "type": "string",
            "description": "Technical description of item effects (GM-visible only)",
            "maxLength": 2555,
            "visible": false
          },
          "effects": {
            "type": "array",
            "description": "Predefined effects applied to the item holder",
            "items": {
              "type": "string",
              "format": "uuid"
            },
            "visible": false
          },
          "unique": {
            "type": "boolean",
            "description": "Whether this is a unique artifact (only one instance can exist)",
            "default": true
          },
          "characters": {
            "type": "array",
            "description": "Characters currently holding this item",
            "items": {
              "type": "string",
              "format": "uuid"
            },
            "visible": false
          }
        }
      },
      "condition": {
        "slug": "condition",
        "title": "Condition",
        "icon": "EmoticonSickOutline",
        "version": "1.0.0",
        "summary": "A positive or negative condition affecting characters",
        "description": "Represents a condition that can be applied to characters as a consequence of gameplay. Conditions differ from skills in that they are not purchased but earned through in-game events.",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Unique name of the condition",
            "maxLength": 255,
            "minLength": 1
          },
          "description": {
            "type": "string",
            "description": "In-game flavor text description",
            "maxLength": 2555
          },
          "effect": {
            "type": "string",
            "description": "Mechanical description of what the condition does",
            "maxLength": 2555,
            "visible": false
          },
          "effects": {
            "type": "array",
            "description": "Automated effects applied by this condition",
            "items": {
              "type": "string",
              "format": "uuid"
            },
            "visible": false
          },
          "unique": {
            "type": "boolean",
            "description": "Whether only one character can have this condition at a time",
            "default": false
          },
          "characters": {
            "type": "array",
            "description": "Characters currently affected by this condition",
            "items": {
              "type": "string",
              "format": "uuid"
            },
            "visible": false
          }
        }
      },
      "effect": {
        "slug": "effect",
        "title": "Effect",
        "icon": "MagicStaff",
        "version": "1.0.0",
        "summary": "A calculated modification to a character ability",
        "description": "Represents a numeric modification to one or more abilities. Effects come from skills, items, conditions, or events and automatically adjust character stats.",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Descriptive name (e.g., +5 Healing Mana)",
            "maxLength": 255,
            "minLength": 1
          },
          "description": {
            "type": "string",
            "description": "Technical description of the effect",
            "maxLength": 2555
          },
          "modifier": {
            "type": "integer",
            "description": "The numeric value applied to the ability",
            "default": 0
          },
          "modification": {
            "type": "string",
            "description": "Whether the modification is positive or negative",
            "enum": [
              "positive",
              "negative"
            ],
            "default": "positive",
            "title": "Modification",
            "facetable": true
          },
          "cumulative": {
            "type": "string",
            "description": "Whether the effect can stack on a character",
            "enum": [
              "cumulative",
              "non-cumulative"
            ],
            "default": "non-cumulative",
            "title": "Cumulative",
            "facetable": true
          },
          "abilities": {
            "type": "array",
            "description": "Abilities this effect modifies",
            "items": {
              "type": "string",
              "format": "uuid"
            },
            "visible": false
          }
        }
      },
      "event": {
        "slug": "event",
        "title": "Event",
        "icon": "CalendarMonthOutline",
        "version": "1.0.0",
        "summary": "A LARP event or gathering where players come together",
        "description": "Represents a LARP event — a gathering where players come with their characters. Can be multi-day events or casual meetups. Characters subscribe to events and receive effects after the event.",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Event name",
            "maxLength": 255,
            "minLength": 1
          },
          "description": {
            "type": "string",
            "description": "Event description",
            "maxLength": 2555
          },
          "startDate": {
            "type": "string",
            "description": "Event start date and time",
            "format": "date-time"
          },
          "endDate": {
            "type": "string",
            "description": "Event end date and time",
            "format": "date-time"
          },
          "location": {
            "type": "string",
            "description": "Event location",
            "maxLength": 255
          },
          "players": {
            "type": "array",
            "description": "Characters participating in this event",
            "items": {
              "type": "string",
              "format": "uuid"
            },
            "visible": false
          },
          "effects": {
            "type": "array",
            "description": "Effects applied to participating characters after the event",
            "items": {
              "type": "string",
              "format": "uuid"
            },
            "visible": false
          }
        }
      },
      "setting": {
        "slug": "setting",
        "title": "Setting",
        "icon": "Cog",
        "version": "1.0.0",
        "summary": "A game setting or configuration value",
        "description": "Represents a game-level setting or configuration parameter for the LARP campaign.",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Setting name",
            "maxLength": 255,
            "minLength": 1
          },
          "description": {
            "type": "string",
            "description": "Description of the setting",
            "maxLength": 2555
          },
          "value": {
            "type": "string",
            "description": "The setting value",
            "maxLength": 2555
          }
        }
      }
    }
  }
}
