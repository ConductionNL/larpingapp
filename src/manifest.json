		{ "id": "Dashboard", "label": "Dashboard", "icon": "icon-category-dashboard", "route": "Dashboard", "order": 10 },
		{ "id": "Characters", "label": "Characters", "icon": "icon-user", "route": "Characters", "order": 20 },
		{ "id": "Players", "label": "Players", "icon": "icon-group", "route": "Players", "order": 30 },
		{ "id": "Items", "label": "Items", "icon": "icon-category-organization", "route": "Items", "order": 40 },
		{ "id": "Events", "label": "Events", "icon": "icon-calendar-dark", "route": "Events", "order": 50 },
		{ "id": "Conditions", "label": "Conditions", "icon": "icon-category-monitoring", "route": "Conditions", "order": 60 },
		{ "id": "Abilities", "label": "Abilities", "icon": "icon-category-security", "route": "Abilities", "section": "settings", "order": 70 },
		{ "id": "Skills", "label": "Skills", "icon": "icon-category-customization", "route": "Skills", "section": "settings", "order": 75 },
