	"pages": [
		{
			"id": "Dashboard",
			"route": "/",
			"type": "dashboard",
			"title": "Dashboard",
			"config": {
				"widgets": [],
				"layout": []
			}
		},
		{
			"id": "Characters",
			"route": "/characters",
			"type": "index",
			"title": "Characters",
			"config": {
				"register": "larpingapp",
				"schema": "character",
				"columns": ["name", "type", "background", "approved", "gold", "silver"],
				"sidebar": { "enabled": true, "showMetadata": true }
			}
		},
		{
			"id": "CharacterDetail",
			"route": "/characters/:id",
			"type": "detail",
			"title": "Character",
			"config": {
				"register": "larpingapp",
				"schema": "character",
				"sidebarTabs": [
					{ "id": "overview", "label": "Overview", "icon": "icon-info", "widgets": [{ "type": "data" }, { "type": "metadata" }], "order": 10 },
					{ "id": "audit", "label": "Audit trail", "icon": "icon-history", "widgets": [{ "type": "audit-trail" }], "order": 90 }
				]
			}
		},
		{
			"id": "Players",
